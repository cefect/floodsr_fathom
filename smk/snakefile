onstart:
    # runs after Snakemake has parsed the workflow and constructed the DAG, right before execution begins.
    # nothing here that assists in rule driving
    print(f"[snakefile.onstart] {datetime.datetime.now()}")
    print(f"[snakefile.onstart] {Path(__file__).name}")
    #import scripts.search_path_config #update search paths (needs to happen before imports)

    #print(f"[snakefile] COMMON_INPUTS:\n    {pprint.pformat(COMMON_INPUTS)}")

    if DEBUG:
        print("\033[95mDEBUG mode is ON\033[0m")

    if not SNAKEMAKE_EP:
        print(f"OUT_DIR: {OUT_DIR}")
        print(f"TEMP_DIR: {TEMP_DIR}")

onsuccess:
    # report total wall-clock runtime for the workflow
    runtime_sec = time.time() - start_time
    print(f"[snakefile.onsuccess] wall clock runtime: {runtime_sec:.1f} sec")

 
