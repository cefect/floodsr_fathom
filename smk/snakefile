# Helper to normalize directory config entries to Path or None


# Parse CLI input from config
OUT_DIR = Path(config.get("out_dir"))
 

#temp dir. using python backend, which pulls from system ENV (TMPDIR , TEMP, TMP)
# matches snakemake behavior
# for usage in rules, use snakemake.resources.tmpdir (handles parallel runs better)
#TEMP_DIR = _dir_from_config(config.get("temp_dir"))
TEMP_DIR = Path(tempfile.gettempdir())

DEBUG = config.get("debug", False)


TILE_CNT = config.get("tile_cnt", 2)
if isinstance(TILE_CNT, str) and TILE_CNT.strip().lower() in {"none", "null", "", 'None'}:
    TILE_CNT = None
HRDEM_ASSET = config.get("hrdem_asset", "dtm")

 
#Directories===============================

OUT_DIR.mkdir(parents=True, exist_ok=True)

# fathom scenario dimensions


 

# Primary Indexers/Wildcards======================
# collect from CLI
IDS = {
    'return_period': parse_config_list(config.get("return_period")),
    'protection': parse_config_list(config.get("protection")),
    'hazard_type': parse_config_list(config.get("hazard_type")),
 
}

for key, value in IDS.items():
    logger.info(f"    Using {key}: {value if value is not None else 'ALL'}")


index_dir = config['fathom_index_dir']
try:
    index_df, IDS, _, cache_hit = load_index(
        index_dir,
        IDS,
        TEMP_DIR / "load_index",
        tile_cnt=TILE_CNT,
        debug=DEBUG, use_cache=True
    )
except Exception as e:
    e.add_note(f"Failed to load filtered index  at {index_dir}")
    raise

logger.info(f"Filtered  index contains {len(index_df):,} rows\n   {index_df.nunique().to_dict()}")

 


    

