# Helper to normalize directory config entries to Path or None


# Parse CLI input from config
OUT_DIR = Path(config.get("out_dir"))
 

#temp dir. using python backend, which pulls from system ENV (TMPDIR , TEMP, TMP)
# matches snakemake behavior
# for usage in rules, use snakemake.resources.tmpdir (handles parallel runs better)
#TEMP_DIR = _dir_from_config(config.get("temp_dir"))
TEMP_DIR = Path(tempfile.gettempdir())

DEBUG = config.get("debug", False)


TILE_CNT = config.get("tile_cnt", 2)
if isinstance(TILE_CNT, str) and TILE_CNT.strip().lower() in {"none", "null", "", 'None'}:
    TILE_CNT = None
HRDEM_ASSET = config.get("hrdem_asset", "dtm")

 
#Directories===============================

OUT_DIR.mkdir(parents=True, exist_ok=True)

{
    "return_period": ["1in5", "1in10", "1in20", "1in50", "1in75", "1in100", "1in200", "1in500", "1in1000"],
    "protection": ["DEFENDED", "UNDEFENDED"],
    "hazard_type": ["FLUVIAL", "PLUVIAL"],
}

 

# Primary Indexers/Wildcards======================
"""rules iterate on tileID

provID and tile_cnt are used to set these tileIDs from teh tile_index_bx 
to allow for more control on runs
"""
 
 

IDS = {    
    'tileID':parse_config_list(config.get("tile_ids"), dtype=str),
    'provID': parse_config_list(config.get("prov_ids"), dtype=int),

}

tile_index_bx, IDS, _, cache_hit = load_or_build_tile_index(
    config.get("domain_ranks_fp"),
    IDS,
    TEMP_DIR / "load_or_build_tile_index",
    tile_cnt=TILE_CNT,
    debug=DEBUG, use_cache=True
)
COMMON_INPUTS.append(config.get("domain_ranks_fp")) #ensure this is shipped to EP

_nu_str= str(tile_index_bx.drop(columns='geometry').nunique().to_dict())
print(f"Tile index index loaded w/ {_nu_str} w/ cache_hit={cache_hit}")

tile_index_bx = tile_index_bx.set_index('tileID').sort_index()

 


    

