# Initialize plib dictionary
plib = {}



# 01 TILE CHUNK--------------------
# d = dict(name='01_chunk')
# d['od'] = os.path.join(OUT_DIR, d['name'], '{tileID}')
# d['ofp'] = os.path.join(d['od'], "01_index_chunk.pkl")  
# plib['r01'] = d.copy()

def get_tile_index_chunk(wildcards):
    """Helper to get tile index chunk for current tileID"""
    chunk = tile_index_bx.loc[[wildcards.tileID]]
    assert isinstance(chunk, gpd.GeoDataFrame)
    return chunk

 
 
# # 02 HRDEM FETCH --------------------        
d = dict(name='02_hrdem')
d['od'] = os.path.join(OUT_DIR, d['name'], '{tileID}')
d['ofp'] = os.path.join(d['od'], "02_hrdem-lidar.tif")  
plib['r02'] = d.copy()

 
rule rA02_hrdem:
    """fetch the HRDEM data for the tile"""
    input:
        *COMMON_INPUTS

        # NO. directory is only for outputs
        # directory('workflow/scripts'),
        # directory('external/RIM2D_py/src')
        

        #f'workflow/scripts/_{plib['r02']['name']}.py' 
    params:
        tile_index_chunk = get_tile_index_chunk,
        DEBUG = DEBUG,
        TEMP_DIR = TEMP_DIR,
        asset = HRDEM_ASSET,
    output:
        plib['r02']['ofp']
    threads: 4
    group: 'EP_t00'
    resources:
        api_calls=1, #global cap on api calls
        # mem = "2GB",
        # disk = "2GB",
        # based on observed usage (~1.2GB mem, ~200MB disk) + 50% buffer
        request_memory = 2000,
        request_disk = 1000000,
        request_gpus = 1,
        # bundle_size = 1,
    #retries: 0
    log:
        os.path.join(plib['r02']['od'], 'snake.log')
    script:
        f'scripts/_{plib['r02']['name']}.py'  




