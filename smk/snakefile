import datetime, tempfile
from pathlib import Path

from parameters import min_depth as MIN_DEPTH
from snakemake.logging import logger

from smk.snakefile_coms import _coerce_bool, load_index, parse_config_list

start_time = datetime.datetime.now()

configfile: "smk/config.yaml"

OUT_DIR = Path(config.get("out_dir"))
OUT_DIR.mkdir(parents=True, exist_ok=True)
PROJECT_CACHE_DIR = Path(config.get("cache_dir", OUT_DIR / ".cache")).resolve()
PROJECT_CACHE_DIR.mkdir(parents=True, exist_ok=True)
TEMP_DIR = Path(tempfile.gettempdir())
DEBUG = bool(_coerce_bool(config.get("debug")) or False)
TILE_CNT = config.get("tile_cnt")
TILE_CNT = None if TILE_CNT in {None, "", "none", "None", "null"} else int(TILE_CNT)

FILTERS_D = {
    "return_period": parse_config_list(config.get("return_period")),
    "protection": parse_config_list(config.get("protection")),
    "hazard_type": parse_config_list(config.get("hazard_type")),
}

index_df = load_index(
    config.get("fathom_index_dir"),
    fathom_tiles_dir=config.get("fathom_tiles_dir"),
    tile_cnt=TILE_CNT,
    filters_d=FILTERS_D,
    cache_dir=PROJECT_CACHE_DIR / "00_load_index",
    debug=DEBUG,
    use_cache=True,
    logger=logger,
)

RUN_COL_L = ["hazard_type", "protection", "return_period", "tileID"]
RUN_RECORD_L = index_df.loc[:, RUN_COL_L].drop_duplicates().to_dict("records")


onstart:
    logger.info(f"snakefile start: {start_time.isoformat()}")
    logger.info(f"workflow rows: {len(index_df):,}")
    logger.info(f"out_dir: {OUT_DIR}")


onsuccess:
    runtime_s = (datetime.datetime.now() - start_time).total_seconds()
    logger.info(f"snakefile success in {runtime_s:.1f}s")


onerror:
    runtime_s = (datetime.datetime.now() - start_time).total_seconds()
    logger.error(f"snakefile failed after {runtime_s:.1f}s")


def _row_from_wildcards(wildcards):
    """Return one normalized load-index row for the current wildcard set."""
    match_df = index_df.loc[
        (index_df["hazard_type"] == wildcards.hazard_type)
        & (index_df["protection"] == wildcards.protection)
        & (index_df["return_period"] == wildcards.return_period)
        & (index_df["tileID"] == wildcards.tileID)
    ]
    assert len(match_df) == 1, f"expected one row for {wildcards}, got {len(match_df)}"
    return match_df.iloc[0]


def _expand_outputs(pattern):
    """Return one output list expanded over the filtered workflow rows."""
    return [pattern.format(**record) for record in RUN_RECORD_L]


def _rule_cache_dir(rule_d):
    """Return one project-local cache directory for the current rule config."""
    return str((PROJECT_CACHE_DIR / rule_d["rule_name"]).resolve())




#===============================================================================
# RULES------
#===============================================================================

plib = {}



# r01_prep -----------------------------
d = dict(name="01_prep")
d["rule_name"] = "r01_prep"
d['od'] = str(OUT_DIR / "01_prep" / "{hazard_type}" / "{protection}" / "{return_period}" / "{tileID}")
d['ofp'] = str(Path(d['od']) / "r01_prep.tif")
plib['r01'] = d.copy()
del d




rule r01_prep:
    input:
        tile_fp=lambda wildcards: _row_from_wildcards(wildcards)["tile_fp"]
    params:
        rule_name=plib["r01"]["rule_name"],
        cache_dir=_rule_cache_dir(plib["r01"]),
        tile_index_chunk=lambda wildcards: _row_from_wildcards(wildcards).to_dict(),
        DEBUG=DEBUG,
        min_depth=float(config.get("min_depth", MIN_DEPTH)),
        manual_window_size=None,
        show_progress=False,
    output:
        r01_prep_fp = plib["r01"]["ofp"]
    threads: 1
    log:
        str(Path(plib["r01"]["od"]) / "snake.log")
    script:
        f"scripts/_{plib['r01']['name']}.py"


rule r01_prep_all:
    input:
        _expand_outputs(plib["r01"]["ofp"])




# r02_hrdem -----------------------------
d = dict(name="02_hrdem")
d["rule_name"] = "r02_hrdem"
d["od"] = str(OUT_DIR / "02_hrdem" / "{hazard_type}" / "{protection}" / "{return_period}" / "{tileID}")
d["ofp"] = str(Path(d["od"]) / "r02_hrdem.vrt")
plib["r02"] = d.copy()
del d

rule r02_hrdem:
    input:
        r01_prep_fp = plib["r01"]["ofp"]
    params:
        rule_name=plib["r02"]["rule_name"],
        cache_dir=_rule_cache_dir(plib["r02"]),
        tile_index_chunk=lambda wildcards: _row_from_wildcards(wildcards).to_dict(),
        DEBUG=DEBUG,
        use_cache=True,
        force_tiling=True, # for vrt
        show_progress=False,
        max_depth=10,
        min_depth_threshold=float(config.get("min_depth", MIN_DEPTH)),
    output:
        r02_hrdem_fp = plib["r02"]["ofp"]
    threads: 4
    resources:
        api_calls=1
    log:
        str(Path(plib["r02"]["od"]) / "snake.log")
    script:
        f"scripts/_{plib['r02']['name']}.py"


rule r02_hrdem_all:
    input:
        _expand_outputs(plib["r02"]["ofp"])


# r03_tohr -----------------------------
d = dict(name="03_tohr")
d["rule_name"] = "r03_tohr"
d["od"] = str(OUT_DIR / "03_tohr" / "{hazard_type}" / "{protection}" / "{return_period}" / "{tileID}")
d["ofp"] = str(Path(d["od"]) / "r03_tohr.vrt")
plib["r03"] = d.copy()
del d


rule r03_tohr:
    input:
        r01_prep_fp = plib["r01"]["ofp"],
        r02_hrdem_fp = plib["r02"]["ofp"]
    params:
        rule_name=plib["r03"]["rule_name"],
        cache_dir=_rule_cache_dir(plib["r03"]),
        tile_index_chunk=lambda wildcards: _row_from_wildcards(wildcards).to_dict(),
        DEBUG=DEBUG,
        model_version=str(config.get("model_version", "ResUNet_16x_DEM")),
        max_depth=10,
        min_depth_threshold=float(config.get("min_depth", MIN_DEPTH)),
        crs_policy="use-dem",
        window_method="hard",
        show_progress=False,
    output:
        r03_tohr_fp = plib["r03"]["ofp"]
    threads: 4
    resources:
        api_calls=1
    log:
        str(Path(plib["r03"]["od"]) / "snake.log")
    script:
        f"scripts/_{plib['r03']['name']}.py"


rule r03_tohr_all:
    input:
        _expand_outputs(plib["r03"]["ofp"])
